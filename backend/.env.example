# Environment Configuration

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pandacafe
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application
APP_NAME=PandaCafe POS
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# API Configuration
API_V1_STR=/api/v1
API_RATE_LIMIT=100/minute

# Printer Configuration
PRINTER_TIMEOUT=10
PRINTER_RETRY_COUNT=3

# Email Configuration (for bill sharing)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@pandacafe.com
SMTP_FROM_NAME=Panda Cafe

# WhatsApp Configuration (optional)
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_BUSINESS_PHONE_ID=your-phone-id

# AWS S3 Configuration (for image storage)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=pandacafe-images
AWS_REGION=us-east-1

# Sentry Configuration (optional)
SENTRY_DSN=

# Feature Flags
ENABLE_OFFLINE_MODE=True
ENABLE_PRINTER_SIMULATION=False
ENABLE_AUDIT_LOGGING=True
ENABLE_NOTIFICATIONS=True
