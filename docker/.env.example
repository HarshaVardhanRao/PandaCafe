# Docker Environment Variables
# Database Configuration
DB_USER=pandacafe
DB_PASSWORD=pandacafe_dev
DB_NAME=pandacafe
DB_HOST=postgres
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Backend Configuration
DATABASE_URL=postgresql://pandacafe:pandacafe_dev@postgres:5432/pandacafe
SECRET_KEY=dev-secret-key-change-in-production-32-chars-min
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost"]

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
